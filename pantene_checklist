<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}

:root{
  --gold-dark:#a8782e;
  --gold-mid:#c9a04e;
  --gold-light:#e8cf8f;
  --gold-pale:#fbf6e9;
  --gold-ultra:#fffdf6;
  --accent-red:#e03a3a;
  --accent-green:#27ae60;
  --text-dark:#2a2418;
  --text-mid:#6b5d42;
  --text-light:#a8987a;
  --border:#ebd9ad;
  --white:#ffffff;
  --shadow:0 2px 12px rgba(168,120,46,0.1);
  --shadow-hover:0 6px 24px rgba(168,120,46,0.18);
}

body{
  font-family:'Noto Sans JP',sans-serif;
  background:linear-gradient(135deg,#fffdf6 0%,#fbf6e9 50%,#f7eed8 100%);
  min-height:100vh;
  padding:16px;
  color:var(--text-dark);
}

.page-header{
  background:linear-gradient(135deg,#3a2f1a 0%,var(--gold-dark) 50%,var(--gold-mid) 100%);
  border-radius:20px;
  padding:24px 20px;
  margin-bottom:20px;
  position:relative;
  overflow:hidden;
  box-shadow:0 8px 32px rgba(168,120,46,0.3);
}
.page-header::before{
  content:'✨';
  position:absolute;
  top:-10px;right:10px;
  font-size:80px;
  opacity:0.15;
}
.page-header::after{
  content:'';
  position:absolute;
  bottom:0;left:0;right:0;
  height:4px;
  background:linear-gradient(90deg,transparent,var(--gold-light),transparent);
}
.header-badge{
  display:inline-block;
  background:var(--white);
  color:var(--gold-dark);
  font-size:11px;
  font-weight:700;
  padding:3px 10px;
  border-radius:20px;
  margin-bottom:8px;
  letter-spacing:0.05em;
}
.page-header h1{
  color:var(--white);
  font-size:20px;
  font-weight:900;
  line-height:1.3;
  margin-bottom:6px;
}
.page-header p{
  color:rgba(255,255,255,0.85);
  font-size:12px;
  line-height:1.5;
}
.total-badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  background:rgba(255,255,255,0.15);
  border:1px solid rgba(255,255,255,0.35);
  border-radius:12px;
  padding:8px 14px;
  margin-top:12px;
  color:var(--white);
  font-size:13px;
  font-weight:700;
}
.total-badge span{
  color:var(--gold-light);
  font-size:18px;
  font-weight:900;
}

.deadline-banner{
  background:linear-gradient(135deg,var(--gold-mid),var(--gold-dark));
  border-radius:14px;
  padding:12px 16px;
  margin-bottom:16px;
  display:flex;
  align-items:center;
  gap:10px;
  box-shadow:0 4px 16px rgba(201,160,78,0.3);
}
.deadline-banner .icon{font-size:24px;}
.deadline-banner .text{color:var(--white);}
.deadline-banner .text strong{font-size:14px;font-weight:900;display:block;}
.deadline-banner .text span{font-size:11px;opacity:0.95;}

.progress-wrap{
  background:var(--white);
  border-radius:16px;
  padding:16px 20px;
  margin-bottom:16px;
  box-shadow:var(--shadow);
  border:1px solid var(--border);
}
.progress-label{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:8px;
  font-size:12px;
  color:var(--text-mid);
  font-weight:700;
}
.progress-label strong{color:var(--gold-dark);font-size:14px;}
.progress-bar-bg{
  background:var(--gold-pale);
  border-radius:8px;
  height:10px;
  overflow:hidden;
}
.progress-bar-fill{
  background:linear-gradient(90deg,var(--gold-light),var(--gold-mid));
  height:100%;
  border-radius:8px;
  transition:width 0.5s ease;
  width:0%;
}

.calc-card{
  background:var(--white);
  border-radius:16px;
  padding:16px;
  margin-bottom:16px;
  box-shadow:var(--shadow);
  border-left:4px solid var(--gold-mid);
}
.calc-title{font-size:13px;font-weight:700;color:var(--gold-dark);margin-bottom:10px;}
.calc-row{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:6px 0;
  border-bottom:1px solid var(--gold-pale);
  font-size:12px;
}
.calc-row:last-child{border-bottom:none;}
.calc-row .label{color:var(--text-mid);}
.calc-row .val{font-weight:700;color:var(--gold-dark);}
.calc-row .val.red{color:var(--accent-red);}
.calc-row .val.green{color:var(--accent-green);}
.calc-total{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-top:10px;
  padding:10px 12px;
  background:var(--gold-pale);
  border-radius:10px;
}
.calc-total .label{font-size:13px;font-weight:700;color:var(--gold-dark);}
.calc-total .val{font-size:18px;font-weight:900;color:var(--accent-green);}

.section{
  background:var(--white);
  border-radius:20px;
  margin-bottom:16px;
  box-shadow:var(--shadow);
  overflow:hidden;
  border:1px solid var(--border);
}
.section-header{
  padding:14px 18px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  cursor:pointer;
  user-select:none;
}
.section-header-left{display:flex;align-items:center;gap:10px;}
.section-icon{
  width:36px;height:36px;
  border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.section-title{font-size:13px;font-weight:700;color:var(--gold-dark);line-height:1.3;}
.section-amount{
  font-size:11px;color:var(--gold-dark);font-weight:700;
  background:var(--gold-light);padding:2px 8px;border-radius:10px;
  margin-top:2px;display:inline-block;
}
.section-chevron{font-size:12px;color:var(--text-light);transition:transform 0.3s;flex-shrink:0;}
.section.collapsed .section-chevron{transform:rotate(-90deg);}
.section-body{padding:0 14px 14px;}
.section.collapsed .section-body{display:none;}

.check-item{
  background:var(--gold-ultra);
  border:1.5px solid var(--border);
  border-radius:14px;
  padding:12px 14px;
  margin-bottom:8px;
  transition:all 0.2s;
  cursor:pointer;
}
.check-item:hover{border-color:var(--gold-light);background:var(--gold-pale);}
.check-item.done{background:#f0fff4;border-color:#a8ddb8;opacity:0.85;}

.item-top{display:flex;align-items:flex-start;gap:10px;}
.checkbox{
  width:22px;height:22px;border-radius:6px;
  border:2px solid var(--gold-light);background:var(--white);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;transition:all 0.2s;margin-top:1px;
}
.check-item.done .checkbox{background:var(--accent-green);border-color:var(--accent-green);}
.checkbox::after{content:'✓';color:var(--white);font-size:13px;font-weight:900;display:none;}
.check-item.done .checkbox::after{display:block;}

.item-content{flex:1;min-width:0;}
.item-label{font-size:13px;font-weight:700;color:var(--text-dark);line-height:1.4;margin-bottom:2px;}
.check-item.done .item-label{text-decoration:line-through;color:var(--text-light);}
.item-detail{font-size:11px;color:var(--text-mid);line-height:1.4;}

.item-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;}
.entry-badge{
  background:var(--accent-red);color:var(--white);
  font-size:9px;font-weight:700;padding:2px 7px;border-radius:8px;white-space:nowrap;
}
.amount-badge{
  background:var(--gold-pale);color:var(--gold-dark);
  font-size:11px;font-weight:700;padding:2px 8px;border-radius:8px;
  white-space:nowrap;border:1px solid var(--border);
}
.check-item.done .amount-badge{background:#e0f5e9;border-color:#a8ddb8;color:var(--accent-green);}

.url-btn{
  display:inline-flex;align-items:center;gap:4px;
  background:var(--gold-mid);color:var(--white) !important;
  font-size:10px;font-weight:700;padding:4px 10px;border-radius:8px;
  text-decoration:none;margin-top:6px;transition:background 0.2s;white-space:nowrap;
}
.url-btn:hover{background:var(--gold-dark);}
.url-btn::before{content:'🔗 ';}

.section-memo{
  background:var(--gold-ultra);border:1.5px dashed var(--border);
  border-radius:12px;padding:12px;margin-top:4px;
}
.section-memo-label{font-size:11px;font-weight:700;color:var(--gold-mid);margin-bottom:6px;}
.memo-textarea{
  width:100%;background:var(--white);border:1.5px solid var(--border);
  border-radius:10px;padding:8px 10px;font-size:12px;
  font-family:'Noto Sans JP',sans-serif;color:var(--text-dark);
  resize:vertical;min-height:56px;line-height:1.6;transition:border-color 0.2s;
}
.memo-textarea:focus{outline:none;border-color:var(--gold-light);box-shadow:0 0 0 3px rgba(232,207,143,0.25);}
.memo-textarea::placeholder{color:var(--text-light);}

.warning-box{
  background:#fff5f5;border:1.5px solid #ffcdd2;
  border-radius:14px;padding:14px 16px;margin-bottom:16px;
}
.warning-title{color:var(--accent-red);font-size:13px;font-weight:700;margin-bottom:10px;}
.warning-item{
  display:flex;align-items:flex-start;gap:8px;margin-bottom:7px;
  font-size:12px;color:var(--text-dark);line-height:1.5;
}
.warning-item::before{content:'⚠️';flex-shrink:0;font-size:11px;}

.tips-box{
  background:var(--gold-pale);border:1.5px solid var(--border);
  border-radius:14px;padding:14px 16px;margin-bottom:16px;
}
.tips-title{color:var(--gold-dark);font-size:13px;font-weight:700;margin-bottom:10px;}
.tips-item{
  display:flex;align-items:flex-start;gap:8px;margin-bottom:7px;
  font-size:12px;color:var(--text-dark);line-height:1.5;
}
.tips-item::before{content:'💡';flex-shrink:0;font-size:11px;}

.dm-box{
  background:var(--gold-pale);border:1.5px solid var(--border);
  border-radius:14px;padding:14px 16px;margin-bottom:16px;
}
.dm-title{color:var(--gold-dark);font-size:13px;font-weight:700;margin-bottom:6px;}
.dm-text{font-size:12px;color:var(--text-dark);line-height:1.6;}

.reset-btn{
  display:block;width:100%;padding:12px;background:var(--white);
  border:2px solid var(--border);border-radius:14px;
  font-family:'Noto Sans JP',sans-serif;font-size:13px;font-weight:700;
  color:var(--text-mid);cursor:pointer;transition:all 0.2s;text-align:center;margin-top:8px;
}
.reset-btn:hover{border-color:var(--accent-red);color:var(--accent-red);}
.save-notice{text-align:center;font-size:11px;color:var(--text-light);padding:8px;}

.other-posts-box{
  background:linear-gradient(135deg,var(--gold-pale),var(--gold-ultra));
  border:1.5px solid var(--border);
  border-radius:14px;padding:14px 16px;margin-bottom:16px;
}
.other-posts-title{color:var(--gold-dark);font-size:13px;font-weight:700;margin-bottom:8px;}
.other-posts-text{font-size:12px;color:var(--text-dark);line-height:1.6;}
</style>
</head>
