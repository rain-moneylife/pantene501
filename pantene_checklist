<button class="reset-btn" onclick="resetAll()">🔄 チェックをリセットする</button>
<p class="save-notice">✅ チェック・メモはブラウザに自動保存されます<br>by rain.moneylife</p>

<script>
const STORAGE_KEY='pantene_checklist_v1';
function getState(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY)||'{}');}catch{return{};}}
function saveState(s){try{localStorage.setItem(STORAGE_KEY,JSON.stringify(s));}catch{}}

function toggleSection(id){
  const sec=document.getElementById(id);
  sec.classList.toggle('collapsed');
  const s=getState();
  s['section_'+id]=sec.classList.contains('collapsed');
  saveState(s);
}

function toggleCheck(el){
  el.classList.toggle('done');
  const s=getState();
  s[el.dataset.key]=el.classList.contains('done');
  saveState(s);
  updateProgress();
}

function updateProgress(){
  const all=document.querySelectorAll('.check-item');
  const done=document.querySelectorAll('.check-item.done');
  const pct=all.length>0?Math.round(done.length/all.length*100):0;
  document.getElementById('progress-text').textContent=done.length+' / '+all.length;
  document.getElementById('progress-bar').style.width=pct+'%';
}

function resetAll(){
  if(!confirm('チェックをすべてリセットしますか？\n（メモは残ります）'))return;
  const s=getState();
  document.querySelectorAll('.check-item').forEach(el=>{
    el.classList.remove('done');
    s[el.dataset.key]=false;
  });
  saveState(s);
  updateProgress();
}

function restoreState(){
  const s=getState();
  document.querySelectorAll('.check-item').forEach(el=>{
    if(s[el.dataset.key])el.classList.add('done');
  });
  document.querySelectorAll('.section').forEach(sec=>{
    if(s['section_'+sec.id])sec.classList.add('collapsed');
  });
  document.querySelectorAll('.memo-textarea').forEach(el=>{
    if(s[el.dataset.key])el.value=s[el.dataset.key];
    el.addEventListener('input',()=>{const s=getState();s[el.dataset.key]=el.value;saveState(s);});
    el.addEventListener('click',e=>e.stopPropagation());
  });
  updateProgress();
}

restoreState();
</script>
